# 智批云后端配置文件示例
# 复制为 .env 并填写真实配置

# 数据库配置
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=123456
DB_NAME=zhipi_cloud

# JWT 配置
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# CORS 配置（前端地址）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
